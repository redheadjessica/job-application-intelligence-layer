# macOS
.DS_Store

# Python
.venv/
venv/
env/
__pycache__/
*.py[cod]

# Node
node_modules/

# Logs / temp
*.log

# Machine-specific local Claude Code settings (regenerated; never commit)
.claude/settings.local.json

# Batch run outputs (keep the empty review folder, ignore generated batches)
__READY TO REVIEW/*/

# ── New explicit-root layout (migration in progress). Everything under the PRIVATE
#    root and the generated-output root is your data — ignored wholesale. Templates and
#    mechanism live under ENGINE__PUBLIC_GIT_TRACKED/ and stay tracked. ─────────────────
PRIVATE__YOUR_FILES_GITIGNORED/
__READY_TO_REVIEW__PRIVATE_GITIGNORED/

# ── Root config: generated instance (by setup/intake). Template is tracked. ──
jail.config.json

# ── Generated candidate-specific INSTANCES (by /intake or /reconcile). ───────
#    Templates (*.template.md) are tracked; these bare-name instances are not.
00-INTAKE/materials-inventory.md
00-INTAKE/resume-assessment.md
04-TAILOR/01-profile.md
04-TAILOR/02-resume-index.md
04-TAILOR/03-approved-truths-and-boundary-rules.md
04-TAILOR/04-experience-bank.md
04-TAILOR/05-summary-quick.md
04-TAILOR/05a-summary-library.md
04-TAILOR/06-skills-quick.md
04-TAILOR/06a-skills-library.md
04-TAILOR/10-bio-library.md
04-TAILOR/learning/learning-ledger.md
04-TAILOR/learning/source-update-queue.md
04-TAILOR/learning/answer-bank.md
04-TAILOR/learning/harvest-backfill-log.md
# Per-pinned-entity canon (candidate-named 03/03b files, e.g. a current venture; no tracked template)
04-TAILOR/03-*.md
04-TAILOR/03b-*.md
!04-TAILOR/03-approved-truths-and-boundary-rules.template.md

# ── Cover-letter module: generated instances (by /cover-letter-intake). ──────
#    Templates (*.template.md / config.template.json) are tracked; instances are not.
04-TAILOR/cover-letter/config.json
04-TAILOR/cover-letter/voice-spec.md
04-TAILOR/cover-letter/eval-rubric.md
04-TAILOR/cover-letter/formatting-spec.md
04-TAILOR/cover-letter/feedback-ledger.md
04-TAILOR/cover-letter/feedback-queue.md
04-TAILOR/cover-letter/writing-links.md
04-TAILOR/cover-letter/anecdote-bank.md
04-TAILOR/cover-letter/exemplars/*
!04-TAILOR/cover-letter/exemplars/README.md

# ── Intake materials (personal). Keep the folder + its README tracked. ───────
00-INTAKE/01-about-you/*
!00-INTAKE/01-about-you/.gitkeep
!00-INTAKE/01-about-you/README.md
00-INTAKE/02-where-you-want-to-go/*
!00-INTAKE/02-where-you-want-to-go/.gitkeep
!00-INTAKE/02-where-you-want-to-go/README.md

# ── Submitted-applications archive (personal). Keep the folder tracked. ──────
05-SUBMITTED-APPLICATIONS/*
!05-SUBMITTED-APPLICATIONS/.gitkeep

# Personal-identifier denylist read by the local pre-commit firewall hook
*denylist.local.txt

# Codex tooling — used for audits only, not part of the product (never commit)
.codex/
